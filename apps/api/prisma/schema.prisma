generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Client {
  id        String   @id @default(uuid())
  name      String
  email     String
  cpf       String   @unique @db.VarChar(11)
  color     String?
  note      String?
  createdAt DateTime @default(now())
}

{
  "name": "techinical-test-eteg",
  "private": true,
  "scripts": {
    "dev": "turbo build --filter=@repo/shared && turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "db:migrate": "pnpm --filter @repo/api exec prisma migrate dev",
    "db:studio": "pnpm --filter @repo/api exec prisma studio",
    "db:generate": "pnpm --filter @repo/api exec prisma generate"
  },
  "devDependencies": {
    "turbo": "^2.5.4",
    "typescript": "^5.8.3"
  },
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=20"
  }
}
